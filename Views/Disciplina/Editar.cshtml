@model Academico.Models.Disciplina

@{
    ViewData["Title"] = "Editar Disciplina";
}

<div class="section">
    <h2 class="section-title">Editar Disciplina</h2>
    <p class="section-sub">Atualize os dados da disciplina</p>
    <div class="divider"></div>

    <div class="card" style="max-width:560px;">
        <form method="post" asp-action="Editar">
            <input type="hidden" asp-for="Id" />
            <input type="hidden" asp-for="AlunoId" />

            <div class="filtro-grupo" style="margin-bottom:1.25rem;">
                <label>Código</label>
                <input asp-for="Codigo" required />
            </div>

            <div class="filtro-grupo" style="margin-bottom:1.25rem;">
                <label>Nome da Disciplina</label>
                <input asp-for="Nome" required />
            </div>

            <div class="filtro-grupo" style="margin-bottom:1.25rem;">
                <label>Docente</label>
                <input asp-for="Docente" required />
            </div>

            <div class="filtro-grupo" style="margin-bottom:1.75rem;">
                <label>Carga Horária</label>
                <input asp-for="CargaHoraria" required />
            </div>

            <div style="display:flex; gap:.75rem;">
                <button type="submit" class="btn btn-primary" style="flex:1;">Salvar</button>
                <a asp-action="Index" asp-route-alunoId="@Model.AlunoId"
                   class="btn btn-outline" style="color:var(--azul); border-color:var(--cinza-borda);">Cancelar</a>
            </div>
        </form>
    </div>
</div>