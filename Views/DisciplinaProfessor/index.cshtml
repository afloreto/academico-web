@model List<Academico.Models.DisciplinaProfessor>

@{
    ViewData["Title"] = "Disciplinas";
    var professor = ViewBag.Professor as Academico.Models.Professor;
}

<div class="section">
    <div style="display:flex; align-items:flex-start; justify-content:space-between; flex-wrap:wrap; gap:1rem; margin-bottom:2rem;">
        <div>
            <h2 class="section-title">Disciplinas de Prof. @professor?.Nome</h2>
            <p class="section-sub">Gerencie as disciplinas ministradas</p>
            <div class="divider"></div>
        </div>
        <div style="display:flex; gap:.75rem;">
            <a asp-action="Adicionar" asp-route-professorId="@professor?.Id" class="btn btn-primary">+ Adicionar Disciplina</a>
            <a asp-controller="Professor" asp-action="Index" class="btn btn-outline" style="color:var(--azul); border-color:var(--cinza-borda);">← Voltar</a>
        </div>
    </div>

    @if (!Model.Any())
    {
        <div class="card" style="text-align:center; padding:3rem; color:var(--texto-leve);">
            Nenhuma disciplina cadastrada ainda.
            <br /><br />
            <a asp-action="Adicionar" asp-route-professorId="@professor?.Id" class="btn btn-primary">+ Adicionar primeira disciplina</a>
        </div>
    }

    @foreach (var d in Model)
    {
        var totalAulas = d.TotalAulas > 0 ? d.TotalAulas : 80;
        var pct = totalAulas > 0 ? (int)((d.AulasMinistradasDadas / (double)totalAulas) * 100) : 0;
        var corBarra = pct >= 75 ? "#1a7a4a" : pct >= 50 ? "#c8973a" : "#e74c3c";

        <div class="card" style="margin-bottom:1.25rem; padding:0; overflow:hidden;">

            <div style="background:var(--cinza-bg); padding:.6rem 1.25rem; border-bottom:1px solid var(--cinza-borda); display:flex; align-items:center; justify-content:space-between; flex-wrap:wrap; gap:.5rem;">
                <span style="font-size:.78rem; color:var(--texto-leve);">@d.Codigo</span>
                <div style="display:flex; gap:.5rem;">
                    <a asp-action="Editar" asp-route-id="@d.Id"
                    style="font-size:.75rem; padding:.25rem .65rem; background:#eef2ff; color:var(--azul-claro); border-radius:5px; font-weight:600; text-decoration:none;">
                        Editar
                    </a>
                    <form method="post" asp-action="Excluir" style="display:inline;"
                        onsubmit="return confirm('Excluir @d.Nome?')">
                        <input type="hidden" name="id" value="@d.Id" />
                        <input type="hidden" name="professorId" value="@d.ProfessorId" />
                        <button type="submit"
                                style="font-size:.75rem; padding:.25rem .65rem; background:#fee2e2; color:#ad0303; border-radius:5px; font-weight:600; border:none; cursor:pointer;">
                            Excluir
                        </button>
                    </form>
                </div>
            </div>

            <div style="padding:.9rem 1.25rem .5rem;">
                <h3 style="font-family:var(--fonte-titulo); font-size:1rem; color:var(--azul); margin:0;">
                    @d.Codigo - @d.Nome [@d.CargaHoraria]
                </h3>
            </div>

            <div style="padding:.5rem 1.25rem 1rem; display:grid; grid-template-columns:repeat(auto-fill, minmax(180px, 1fr)); gap:.75rem 1.5rem;">
                <div>
                    <div style="font-size:.72rem; color:var(--texto-leve); text-transform:uppercase; letter-spacing:.05em; margin-bottom:.2rem;">Turno</div>
                    <div style="font-size:.85rem; color:var(--texto);">@(string.IsNullOrEmpty(d.Turno) ? "—" : d.Turno)</div>
                </div>
                <div>
                    <div style="font-size:.72rem; color:var(--texto-leve); text-transform:uppercase; letter-spacing:.05em; margin-bottom:.2rem;">Qtd. Alunos</div>
                    <div style="font-size:.85rem; color:var(--azul-claro); font-weight:600;">@d.QuantidadeAlunos</div>
                </div>
                <div>
                    <div style="font-size:.72rem; color:var(--texto-leve); text-transform:uppercase; letter-spacing:.05em; margin-bottom:.2rem;">Horário</div>
                    <div style="font-size:.85rem; color:var(--texto);">@(string.IsNullOrEmpty(d.Horario) ? "—" : d.Horario)</div>
                </div>
                <div>
                    <div style="font-size:.72rem; color:var(--texto-leve); text-transform:uppercase; letter-spacing:.05em; margin-bottom:.2rem;">Local</div>
                    <div style="font-size:.85rem; color:var(--texto);">@(string.IsNullOrEmpty(d.LocalAula) ? "—" : d.LocalAula)</div>
                </div>
            </div>

            <div style="padding:.5rem 1.25rem 1.25rem;">
                <div style="font-size:.72rem; color:var(--texto-leve); text-transform:uppercase; letter-spacing:.05em; margin-bottom:.4rem;">
                    Aulas Ministradas &nbsp;·&nbsp; @d.AulasMinistradasDadas de @totalAulas aulas
                </div>
                <div style="display:flex; align-items:center; gap:.75rem;">
                    <div style="flex:1; height:18px; background:var(--cinza-borda); border-radius:4px; overflow:hidden;">
                        <div style="width:@(pct)%; height:100%; background:@corBarra; border-radius:4px;"></div>
                    </div>
                    <span style="font-size:.82rem; font-weight:700; color:@corBarra; min-width:36px;">@(pct)%</span>
                </div>
            </div>

        </div>
    }
</div>
